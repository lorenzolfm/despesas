# Google Sheets API Configuration
# See docs/GOOGLE_SHEETS_INTEGRATION.md for setup instructions

# Your Google Sheet ID (from the URL: https://docs.google.com/spreadsheets/d/{SHEET_ID}/edit)
GOOGLE_SHEETS_ID=your-sheet-id-here

# Service Account Email (from Google Cloud Console)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# Service Account Private Key (from the downloaded JSON key file)
# Copy the entire private_key value including the BEGIN/END markers
# Keep the \n characters as-is
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Authentication (Auth.js / @auth/sveltekit)
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-auth-secret-here

# Google OAuth 2.0 (from Google Cloud Console > APIs & Services > Credentials)
AUTH_GOOGLE_ID=your-oauth-client-id
AUTH_GOOGLE_SECRET=your-oauth-client-secret

# Comma-separated list of allowed Google account emails
ALLOWED_EMAILS=person@example.com,otherperson@example.com
